PORT=4000
NODE_ENV=development
LOG_LEVEL=info

DATABASE_URL="postgresql://postgres:password@localhost:5432/taskflow"
CORS_ORIGIN="http://localhost:5173"
FRONTEND_URL="http://localhost:5173"

JWT_ACCESS_SECRET="change-me-access-secret-at-least-16-chars"
JWT_REFRESH_SECRET="change-me-refresh-secret-at-least-16-chars"
JWT_RESET_SECRET="change-me-reset-secret-at-least-16-chars"
JWT_INVITE_SECRET="change-me-invite-secret-at-least-16-chars"
INVITE_TOKEN_SECRET="change-me-invite-token-secret-at-least-16-chars"

TTL_ACCESS_TOKEN=15m
TTL_REFRESH_TOKEN=7d
TTL_RESET_TOKEN=15m
TTL_INVITE_TOKEN=7d

EMAIL_USER="your-email@example.com"
EMAIL_APP_PASSWORD="your-email-app-password"
EMAIL_FROM="TaskFlow <your-email@example.com>"
